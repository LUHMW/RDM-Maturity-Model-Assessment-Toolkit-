        <Literal>Daten identifizieren und selektieren, die für die (Langzeit-)Archivierung erhalten werden sollen (basierend auf Nutzen, Qualität, Zielgruppe).</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
