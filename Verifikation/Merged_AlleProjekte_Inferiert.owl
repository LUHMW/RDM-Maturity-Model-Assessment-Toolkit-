        <Literal>Ab Beginn der Veröffentlichung wird die Datenvorbereitung nach definierten Qualitätskriterien überprüft.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
