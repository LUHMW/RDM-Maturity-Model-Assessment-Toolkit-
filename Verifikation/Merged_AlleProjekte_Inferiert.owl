        <Literal>Verantwortlichkeiten für die Qualitätsprüfung der (Meta-)Daten und Dokumentation definieren.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>http://www.semanticweb.org/thilohauer/ontologies/2024/9/untitled-ontology-34#P3_4_2_1</IRI>
        <Literal>(Meta-)Datenqualität anhand definierter Qualitätsdimensionen und -metriken prüfen.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>http://www.semanticweb.org/thilohauer/ontologies/2024/9/untitled-ontology-34#P3_4_2_2</IRI>
        <Literal>Einen kontinuierlichen Qualitätskontrollprozess implementieren (manuell/automatisiert).</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>http://www.semanticweb.org/thilohauer/ontologies/2024/9/untitled-ontology-34#P3_4_2_3</IRI>
        <Literal>Werkzeuge zur Qualitätskontrolle der (Meta-)Daten einsetzen (Skripte, Checklisten, Software).</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
