</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P3_4_2_1">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">(Meta-)Datenqualität anhand definierter Qualitätsdimensionen und -metriken prüfen.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P3_4_2_2">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Einen kontinuierlichen Qualitätskontrollprozess implementieren (manuell/automatisiert).</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P3_4_2_3">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Werkzeuge zur Qualitätskontrolle der (Meta-)Daten einsetzen (Skripte, Checklisten, Software).</rdfs:comment>
</owl:NamedIndividual>

