<owl:NamedIndividual rdf:about="#P2_2_5_1">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Eine Sicherungsstrategie für (Meta-)Daten und Forschungsergebnisse entwickeln, einschließlich Versionierung.</rdfs:comment>
