  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Die Dokumentation des Erhebungsprozesses wird ab Beginn der Erhebung mit geeigneten Werkzeugen durchgeführt.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P2_2_3_1">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Die Dokumentation mit einem definierten Werkzeug (z. B. elektronisches Laborbuch) erstellen.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P2_2_3_2">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Eine methodenspezifische Dokumentationsvorlage entwickeln, um den Ablauf, verwendete Materialien, Beobachtungen und Metadaten strukturiert zu erfassen.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P2_2_3_3">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Ein maschinenlesbares Format für Metadaten definieren.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Z2_2_4">
  <rdf:type rdf:resource="#Technisches_Ziel"/>
  <erreichtDurch rdf:resource="#P2_2_4_1"/>
