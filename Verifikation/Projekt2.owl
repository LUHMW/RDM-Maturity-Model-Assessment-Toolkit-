  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kriterien zur Qualitätsmessung von Metadaten werden bis zum Start der Erhebung definiert.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P2_4_2_1">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Quantitative Kriterien für die Qualität der Dokumentation festlegen (z. B. Aufwand und Effizienz).</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P2_4_2_2">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Quantitative Kriterien für die Qualität der Metadaten definieren (z. B. Konsistenz, Prägnanz, Vollständigkeit).</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P2_4_2_3">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Eine Expertenprüfung der Dokumentation zur Sicherstellung der Eindeutigkeit durchführen.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P2_4_2_4">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Verantwortlichkeiten für die Qualitätskontrolle der Metadaten festlegen.</rdfs:comment>
