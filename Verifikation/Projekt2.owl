</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P2_3_1_1">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Domänen- und communityspezifische Standards für die Dokumentation von (Meta-)Daten identifizieren.</rdfs:comment>
