  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Die Speicherung, Strukturierung und Sicherung der weiterverarbeiteten und aggregierten Daten sowie Metadaten und Dokumentationen  erfolgen unsystematisch und individuell (Speichersysteme, die gerade zur Verfügung stehen).</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P3_1_3_1">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">None</rdfs:comment>
