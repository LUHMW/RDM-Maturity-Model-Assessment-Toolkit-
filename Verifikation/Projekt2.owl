  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Die Archivierung erfolgt intuitiv mit ad hoc gewählten Ressourcen und Werkzeugen.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P4_1_2_1">
  <rdf:type rdf:resource="#Praktik"/>
