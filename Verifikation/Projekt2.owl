<owl:NamedIndividual rdf:about="#P3_4_3_2">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Die Genauigkeit und Objektivität der Dokumentation durch Experten prüfen lassen.</rdfs:comment>
