</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P2_3_2_1">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Domänen- und communityspezifische Standards für Erhebungsmethoden identifizieren.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P2_3_2_2">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Erhebungsmethoden definieren, die in der Domäne oder Community zur Zielerreichung eingesetzt werden.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P2_3_2_3">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relevante Datenarten, -typen, -formate und -mengen identifizieren, die in der Domäne oder Community anerkannt sind.</rdfs:comment>
