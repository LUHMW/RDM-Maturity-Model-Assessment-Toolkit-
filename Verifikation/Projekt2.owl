  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Analyse, Dokumentation und Organisation werden mit in der Domäne oder Community etablierten Werkzeugen durchgeführt.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P3_3_4_1">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Ein domänen- oder communityspezifisches Workflow-Werkzeug für die Dokumentation verwenden.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P3_3_4_2">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Ein in der Domäne oder Community etabliertes Werkzeug zur Bearbeitung der (Meta-)Daten einsetzen.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Z3_4_1">
