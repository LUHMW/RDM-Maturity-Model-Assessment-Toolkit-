<owl:NamedIndividual rdf:about="#P2_5_1_2">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mit Infrastruktureinrichtungen und Experten zur Kompetenzentwicklung und nachhaltigen Infrastruktur kooperieren.</rdfs:comment>
