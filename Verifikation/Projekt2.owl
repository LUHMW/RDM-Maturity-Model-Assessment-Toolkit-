  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Erhebungsmethoden anpassen oder neu gestalten, um eine präzise Datenerfassung sicherzustellen.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P2_4_1_4">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Verantwortlichkeiten für die Qualitätsprüfung der erhobenen Daten definieren.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Z2_4_2">
