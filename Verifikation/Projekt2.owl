  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Die Weiterverarbeitung der Daten und  Dokumentation wird mit intuitiv ausgewählten Instrumenten ausgeführt (Instrumente , die gerade zur Verfügung stehen).</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P3_1_2_1">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">None</rdfs:comment>
</owl:NamedIndividual>

