<owl:NamedIndividual rdf:about="#Z1_1_1">
  <rdf:type rdf:resource="#Methodisches_Ziel"/>
  <erreichtDurch rdf:resource="#P1_1_1_1"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bis zum Projektstart wird die Umsetzung
des  FDM für das Forschungsprojekt intuitiv und ad hoc geplant.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P1_1_1_1">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">neu neu neu</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Z1_1_2">
  <rdf:type rdf:resource="#Technisches_Ziel"/>
  <erreichtDurch rdf:resource="#P1_1_2_1"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bis zum Projektstart wird ad hoc und intuitiv ein DMP, der für das Forschungsprojekt relevante Kernbereiche des FDM enthält, erstellt.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P1_1_2_1">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">None</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Z1_2_1">
  <rdf:type rdf:resource="#Methodisches_Ziel"/>
  <erreichtDurch rdf:resource="#P1_2_1_1"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Anforderungen und Vorgaben der Stakeholder für das Forschungsdatenmanagement im Projekt werden bis zum Projektstart identifiziert und dokumentiert.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P1_2_1_1">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Informationsmaterialien der Stakeholder analysieren und nutzen, um Anforderungen und Vorgaben für die im Projekt eingesetzten Forschungsmethoden zu ermitteln.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Z1_2_2">
  <rdf:type rdf:resource="#Methodisches_Ziel"/>
  <erreichtDurch rdf:resource="#P1_2_2_1"/>
  <erreichtDurch rdf:resource="#P1_2_2_2"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Eine DMP-Vorlage, die die relevanten Kernbereiche des Forschungsdatenmanagements im Projekt abdeckt, wird bis zum Projektstart geplant und etabliert.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P1_2_2_1">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Eine von den Stakeholdern bereitgestellte DMP-Vorlage verwenden, um den projektspezifischen DMP zu erstellen.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P1_2_2_2">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Eine eigene DMP-Vorlage entwickeln, die die Anforderungen und Vorgaben der Stakeholder berücksichtigt und alle relevanten Kernbereiche des FDM abbildet.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Z1_2_3">
  <rdf:type rdf:resource="#Methodisches_Ziel"/>
  <erreichtDurch rdf:resource="#P1_2_3_1"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Die Arbeitsabläufe des Forschungsdatenmanagements werden bis zum Projektstart auf Basis der DMP-Vorlage geplant und dokumentiert.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P1_2_3_1">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Strategien zur Steuerung der Arbeitsabläufe in den Kernbereichen des DMP (Ziele, Prioritäten, Umfang, Ressourcen) planen und definieren.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Z1_2_4">
  <rdf:type rdf:resource="#Technisches_Ziel"/>
  <erreichtDurch rdf:resource="#P1_2_4_1"/>
  <erreichtDurch rdf:resource="#P1_2_4_2"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Der DMP wird bis zum Projektstart mit einem geeigneten Werkzeug basierend auf der geplanten DMP-Vorlage erstellt.</rdfs:comment>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Der DMP wird bis zum Projektstart mit einem geeigneten Werkzeug erstellt, das auf der geplanten DMP-Vorlage basiert.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P1_2_4_1">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Ein von den Stakeholdern vorgegebenes Werkzeug (Hard- oder Software) für die Erstellung des DMP verwenden.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P1_2_4_2">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Ein geeignetes Werkzeug (Hard- oder Software) auswählen, das die Anforderungen und Vorgaben erfüllt, und damit den DMP erstellen.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Z1_3_1">
  <rdf:type rdf:resource="#Methodisches_Ziel"/>
  <erreichtDurch rdf:resource="#P1_3_1_1"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Das Forschungsdatenmanagement bezieht bis zum Projektstart domänen- und communityspezifische Standards sowie die Anforderungen der Stakeholder ein.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P1_3_1_1">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Standards in der Domäne und Community für relevante FDM-Bereiche identifizieren und dokumentieren.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Z1_3_2">
  <rdf:type rdf:resource="#Methodisches_Ziel"/>
  <erreichtDurch rdf:resource="#P1_3_2_1"/>
  <erreichtDurch rdf:resource="#P1_3_2_2"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Eine DMP-Vorlage, die auf domänen- und communityspezifischen Standards basiert, wird bis zum Projektstart etabliert.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P1_3_2_1">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Eine standardisierte DMP-Vorlage der Stakeholder verwenden, die auf anerkannten Standards basiert.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P1_3_2_2">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Eine eigene DMP-Vorlage entwickeln, die domänen- oder communityspezifische Standards für die Forschungsmethoden des Projekts berücksichtigt.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Z1_3_3">
  <rdf:type rdf:resource="#Methodisches_Ziel"/>
  <erreichtDurch rdf:resource="#P1_3_3_1"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Die Arbeitsabläufe des FDM werden bis zum Projektstart nach domänen- oder communityspezifischen Standards geplant.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P1_3_3_1">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Strategien zur Steuerung der Arbeitsabläufe basierend auf domänen- oder communityspezifischen Standards planen und definieren.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Z1_3_4">
  <rdf:type rdf:resource="#Technisches_Ziel"/>
  <erreichtDurch rdf:resource="#P1_3_4_1"/>
  <erreichtDurch rdf:resource="#P1_3_4_2"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Der DMP wird bis zum Projektstart mit einem domänen- oder communityspezifischen Werkzeug erstellt.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P1_3_4_1">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Ein in der Domäne oder Community etabliertes Werkzeug (Hard- oder Software) für die Erstellung des DMP verwenden.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P1_3_4_2">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Ein Werkzeug auswählen, das mit domänen- und communityspezifischen Standards konform ist.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Z1_4_1">
  <rdf:type rdf:resource="#Methodisches_Ziel"/>
  <erreichtDurch rdf:resource="#P1_4_1_1"/>
  <erreichtDurch rdf:resource="#P1_4_1_2"/>
  <erreichtDurch rdf:resource="#P1_4_1_3"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Der DMP ist während des Projekts ein lebendes Dokument und wird fortlaufend auf Basis von Qualitätszielen aktualisiert.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P1_4_1_1">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Den DMP vor der Datenerhebung erstellen und bei Vorliegen neuer Informationen zu Datentypen, -quellen, -volumen und -formaten aktualisieren.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P1_4_1_2">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Ein Revisionsprotokoll führen, das alle Änderungen des DMP dokumentiert.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P1_4_1_3">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Rollen und Verantwortlichkeiten für FDM-Aufgaben, einschließlich Überwachung und Aktualisierung des DMP, klar definieren.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Z1_4_2">
  <rdf:type rdf:resource="#Methodisches_Ziel"/>
  <erreichtDurch rdf:resource="#P1_4_2_1"/>
  <erreichtDurch rdf:resource="#P1_4_2_2"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bis zur Antragseinreichung wird sichergestellt, dass der DMP vollständig ist und für alle Kernbereiche die Umsetzung und für anfallende Daten die Handhabung dieser geplant sind.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P1_4_2_1">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Innerhalb des DMP überprüfen, ob alle Felder ausgefüllt sind.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P1_4_2_2">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bestehende Leerstellen identifizieren und inhaltlich ausfüllen und nachbessern.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Z1_4_3">
  <rdf:type rdf:resource="#Methodisches_Ziel"/>
  <erreichtDurch rdf:resource="#P1_4_3_1"/>
  <erreichtDurch rdf:resource="#P1_4_3_2"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bis zur Antragseinreichung wird überprüft und dokumentiert, dass die geplanten Inhalte des DMP in allen Kernbereichen für die im Projekt anfallenden Daten relevant und angemessen sind.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P1_4_3_1">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Den DMP basierend auf definierten Qualitätskriterien durch Fachpersonal oder externe Prüfer evaluieren lassen.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P1_4_3_2">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Identifizierte Verbesserungspotentiale inhaltlich nachbessern.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Z1_4_4">
  <rdf:type rdf:resource="#Technisches_Ziel"/>
  <erreichtDurch rdf:resource="#P1_4_4_1"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Geeignete Werkzeuge zur Qualitätsprüfung und kontinuierlichen Sicherung des DMP werden bis zum Projektstart identifiziert und bereitgestellt.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P1_4_4_1">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Technische Grundlage für eine kontinuierliche Aktualisierung und Versionierung oder auch Vollständigkeit sowie Relevanz identifizieren und bei Möglichkeit nutzen. </rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Z1_5_1">
  <rdf:type rdf:resource="#Methodisches_Ziel"/>
  <erreichtDurch rdf:resource="#P1_5_1_1"/>
  <erreichtDurch rdf:resource="#P1_5_1_2"/>
  <erreichtDurch rdf:resource="#P1_5_1_3"/>
  <erreichtDurch rdf:resource="#P1_5_1_4"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Im Rahmen des Forschungsprojektes wird aktiv und dauerhaft zur Weiterentwicklung von Standards und Best Practices im FDM beigetragen.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P1_5_1_1">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Auf die Einhaltung und Weiterentwicklung von Qualitätsstandards in der Community achten.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P1_5_1_2">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">An Arbeitsgruppen und Konsortien zur Entwicklung und zum Austausch von FDM-Praktiken teilnehmen.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P1_5_1_3">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Arbeits- und Zwischenergebnisse sowie DMP-Vorlagen aktiv mit der Community teilen und diskutieren.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P1_5_1_4">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bei der Erstellung und Verbreitung von Fragenkatalogen zu domänenspezifischen Forschungsmethoden mitwirken.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Z1_5_2">
  <rdf:type rdf:resource="#Methodisches_Ziel"/>
  <erreichtDurch rdf:resource="#P1_5_2_1"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Methodische und technische Ziele des FDM für die Projektplanung werden kontinuierlich optimiert und verbessert.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P1_5_2_1">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Verfügbare Kompetenzen und Ressourcen der Domäne oder Community nutzen, um die Datenmanagementplanung auf dem neuesten Stand zu halten.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Z2_1_1">
  <rdf:type rdf:resource="#Methodisches_Ziel"/>
  <erreichtDurch rdf:resource="#P2_1_1_1"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Die Dokumentation und Erstellung von (Meta-)Daten abhängig
von der/den Erhebungsmethode(n) wird intuitiv ausgelegt und unsystematisch ausgeführt.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P2_1_1_1">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">None</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Z2_1_2">
  <rdf:type rdf:resource="#Technisches_Ziel"/>
  <erreichtDurch rdf:resource="#P2_1_2_1"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Die Erhebung der (Meta-)Daten wird mit intuitiv ausgewählten Instrumenten ausgeführt (Instrumente für Erhebungsmethode(n), die gerade zur Verfügung stehen).</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P2_1_2_1">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">None</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Z2_1_3">
  <rdf:type rdf:resource="#Technisches_Ziel"/>
  <erreichtDurch rdf:resource="#P2_1_3_1"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Die Speicherung, Strukturierung und Sicherung der erhobenen Daten erfolgt unsystematisch und individuell (Speichersysteme, die gerade zur Verfügung stehen).</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P2_1_3_1">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">None</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Z2_2_1">
  <rdf:type rdf:resource="#Methodisches_Ziel"/>
  <erreichtDurch rdf:resource="#P2_2_1_1"/>
  <erreichtDurch rdf:resource="#P2_2_1_2"/>
  <erreichtDurch rdf:resource="#P2_2_1_3"/>
  <erreichtDurch rdf:resource="#P2_2_1_4"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Der Umfang der Dokumentation für die Erhebungsmethoden im Arbeitspaket wird bis zum Start der Erhebung geplant und definiert.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P2_2_1_1">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relevante Datenparameter identifizieren, die im Rahmen des Forschungsziels zu dokumentieren sind, einschließlich Abweichungen und Einflüssen.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P2_2_1_2">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Projektbezogene Metadaten (deskriptive, administrative, strukturelle, technische, rechtliche, bestandsführungsbezogene) definieren.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P2_2_1_3">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Ein kontrolliertes Vokabular für die im Projekt verwendeten Metadaten definieren.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P2_2_1_4">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Verantwortlichkeiten, Aufgaben und Ressourcen für die Erfassung von (Meta-)Daten in den Erhebungsmethoden festlegen.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Z2_2_2">
  <rdf:type rdf:resource="#Methodisches_Ziel"/>
  <erreichtDurch rdf:resource="#P2_2_2_1"/>
  <erreichtDurch rdf:resource="#P2_2_2_2"/>
  <erreichtDurch rdf:resource="#P2_2_2_3"/>
  <erreichtDurch rdf:resource="#P2_2_2_4"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Die Erhebungsmethoden und -verfahren werden bis zum Start der Erhebung auf das Forschungsziel des Arbeitspakets ausgerichtet.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P2_2_2_1">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Die zur Erreichung des Forschungsziels erforderlichen Erhebungsmethoden und -verfahren identifizieren und definieren.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P2_2_2_2">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Datenarten, -typen, -formate und -mengen identifizieren, die voraussichtlich im Rahmen der Erhebung anfallen.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P2_2_2_3">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Ein geeignetes Speichermedium für (Meta-)Daten identifizieren und definieren.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P2_2_2_4">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Verantwortlichkeiten und Ressourcen für die Erhebungsmethoden (Instrumente, Soft-/Hardware, Personal) festlegen.</rdfs:comment>
</owl:NamedIndividual>

