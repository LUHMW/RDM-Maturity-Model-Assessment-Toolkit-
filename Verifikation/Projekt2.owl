<owl:NamedIndividual rdf:about="#Z3_1_1">
  <rdf:type rdf:resource="#Methodisches_Ziel"/>
  <erreichtDurch rdf:resource="#P3_1_1_1"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Die Dokumentation und Erstellung von Metadaten abhängig
von der Weiterverarbeitung der Daten wird intuitiv ausgelegt und unsystematisch ausgeführt.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P3_1_1_1">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">None</rdfs:comment>
