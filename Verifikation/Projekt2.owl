  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Die Datenerhebung wird ab Beginn mit definierten Werkzeugen und Ressourcen durchgeführt.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P2_2_4_1">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Für die Datenerhebung die definierten Ressourcen und Werkzeuge entsprechend der Erhebungsmethoden nutzen.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P2_2_4_2">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Ein geeignetes Speichermedium für (Meta-)Daten auswählen, das Datensicherheit und -erhaltung berücksichtigt.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Z2_2_5">
  <rdf:type rdf:resource="#Technisches_Ziel"/>
  <erreichtDurch rdf:resource="#P2_2_5_1"/>
