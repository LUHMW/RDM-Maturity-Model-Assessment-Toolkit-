</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P2_4_3_1">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Regelmäßige Qualitätsberichte verfassen, um Fehlerquellen zu identifizieren.</rdfs:comment>
