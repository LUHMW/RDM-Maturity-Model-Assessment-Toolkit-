</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P2_4_4_1">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mit einer Checkliste empfohlene Qualitätskriterien zu Metadaten prüfen (Formate, Vokabular, Struktur).</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P2_4_4_2">
  <rdf:type rdf:resource="#Praktik"/>
