</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P2_3_3_2">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Eine Dokumentationsvorlage gemäß domänen- oder communityspezifischen Standards erstellen.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P2_3_3_3">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Einen anerkannten Metadatenstandard mit maschinenlesbaren Formaten nutzen.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P2_3_3_4">
