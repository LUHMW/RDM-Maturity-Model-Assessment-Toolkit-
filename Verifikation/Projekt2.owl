<owl:NamedIndividual rdf:about="#P2_2_5_2">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Eine konsistente Ordnerstruktur für Speicherung und Zugriff entwickeln.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P2_2_5_3">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">README-Dateien für die Datenorganisation erstellen.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P2_2_5_4">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Verantwortlichkeiten für Datenspeicherung und -organisation festlegen.</rdfs:comment>
</owl:NamedIndividual>

