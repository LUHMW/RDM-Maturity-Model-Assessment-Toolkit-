<owl:NamedIndividual rdf:about="#P2_3_1_3">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Etablierte Metadatenstandards und zugehörige Formate und Vokabulare nutzen.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P2_3_1_4">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Metadaten definieren, die domänen- und communityspezifische Anforderungen einbeziehen.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P2_3_1_5">
  <rdf:type rdf:resource="#Praktik"/>
