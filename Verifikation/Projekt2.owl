  <erreichtDurch rdf:resource="#P3_4_1_4"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bis zum Start der Analyse werden in der Domäne oder Community etablierte Qualitätsziele und -kriterien für (Meta-)Daten und Dokumentation berücksichtigt.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P3_4_1_1">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Explizite Qualitätsdimensionen und -metriken identifizieren und etablieren, die innerhalb der Community anerkannt sind.</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P3_4_1_2">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Quantitative Kriterien für die Qualitätsmessung definieren (z. B. Inhalt, Vokabular, Format).</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P3_4_1_3">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kriterien und Ziele zur Anwendung und Implementierung von Verfahren und Werkzeugen festlegen (Nachvollziehbarkeit, Vollständigkeit).</rdfs:comment>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#P3_4_1_4">
  <rdf:type rdf:resource="#Praktik"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Verantwortlichkeiten für die Qualitätsprüfung der (Meta-)Daten und Dokumentation definieren.</rdfs:comment>
</owl:NamedIndividual>

